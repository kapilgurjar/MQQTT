	private static final Set<String> failedDevices =
            Collections.synchronizedSet(
                    new HashSet<>());
	
	
	
	@Test(invocationCount = 1)
	public void validateDiscoveryAndHeartbeatFlow() {
		
		failedDevices.clear();
		MetricsCollector.clear();

		try {
		    List<DeviceInfo> devices = CsvReaderUtil.readDevices(
		            "./src/main/resources/devices.csv");

		    System.out.println("Total Devices : " + devices.size());

		    
		    System.out.println("Pre-loading SSL factories...");
		    for (DeviceInfo device : devices) {
		        AwsIotSslUtil.getSocketFactory(
		                device.getP12Path(),
		                device.getPassword());
		    }
		    System.out.println("SSL ready. Starting test...");

		  
		    ExecutorService executor = Executors.newFixedThreadPool(50);

		   
		    CountDownLatch completionLatch = new CountDownLatch(devices.size());

		    for (DeviceInfo device : devices) {
		    	executor.submit(() -> {
		    	    try {
		    	        System.out.println("Starting Discovery : " + device.getDeviceId());
		    	        new DeviceWorkerNew(device).execute();
		    	        

		    	        boolean discovered = waitForDeviceInDB(device.getDeviceId(), 30, 2);
		    	        if (!discovered) {
		    	            throw new Exception(
		    	                    "Device not found in DB after discovery : "
		    	                    + device.getDeviceId());
		    	        }

		    	        System.out.println("Starting Heartbeat : " + device.getDeviceId());
		    	        String sentTime = new HeartbeatWorker1(device).execute();
		    	        System.out.println("Heartbeat Sent Time : " + sentTime);

		    	        String dbTime = waitForHeartbeatInDB(device.getDeviceId(), sentTime, 30, 2);
		    	        System.out.println("DB Heartbeat Time : " + dbTime);
//
//		    	        if (!sentTime.equals(dbTime)) {
//		    	            throw new AssertionError(
//		    	                    "Heartbeat timestamp mismatch for device "
//		    	                    + device.getDeviceId()
//		    	                    + " | sent=" + sentTime
//		    	                    + " | db=" + dbTime);
//		    	        }
		    	        
		    	        
		    	        Instant sent = Instant.parse(sentTime);
		    	        Instant db = Instant.parse(dbTime);

		    	        long diff =
		    	                Math.abs(Duration.between(sent, db).getSeconds());

		    	        if (diff > 2) {
		    	            throw new AssertionError(
		    	                    "Heartbeat timestamp mismatch for device "
		    	                    + device.getDeviceId()
		    	                    + " | sent=" + sentTime
		    	                    + " | db=" + dbTime
		    	                    + " | diff=" + diff + " sec");
		    	        }
		    	        

		    	    } catch (AssertionError ae) {
		    	        failedDevices.add(device.getDeviceId());
		    	        System.out.println("\nAssertion Failed : " + device.getDeviceId());
		    	        System.out.println(ae.getMessage());
		    	       
		    	        MetricsCollector.addResult(
		    	                new ResultInfo(device.getDeviceId(), 0, false));

		    	    } catch (Exception e) {
		    	        failedDevices.add(device.getDeviceId());
		    	        System.out.println("\nFailed Device : " + device.getDeviceId());
		    	        e.printStackTrace();
		    	        MetricsCollector.addResult(
		    	                new ResultInfo(device.getDeviceId(), 0, false));

		    	    } finally {
		    	        completionLatch.countDown();
		    	    }
		    	});
		    	
		    	 Thread.sleep(50);
		    }

		    
		    boolean allFinished = completionLatch.await(10, TimeUnit.MINUTES);
		    if (!allFinished) {
		        System.err.println("WARNING: Test timed out — not all devices completed");
		    }

		    executor.shutdown();

		   
		    long failed = MetricsCollector.getResults()
		            .stream()
		            .filter(r -> !r.isSuccess())
		            .count();

		    if (MetricsCollector.getResults().size() != devices.size()) {
		        System.out.println(
		                "WARNING: Missing results. Started="
		                + devices.size()
		                + " Recorded="
		                + MetricsCollector.getResults().size());
		    }

		    MetricsCollector.printSummary();
		    
		    List<ResultInfo> slowestDevices = MetricsCollector.getResults().stream()
		            .filter(ResultInfo::isSuccess)
		            .sorted((r1, r2) -> Long.compare(r2.getLatency(), r1.getLatency()))
		            .limit(5)
		            .toList();

		    ReportGenerator.generateReport(
		            MetricsCollector.getResults(),
		            MetricsCollector.getAverageLatency(),
		            MetricsCollector.getP95(),
		            MetricsCollector.getP99(),
		            MetricsCollector.getSuccessCount(),
		            MetricsCollector.getFailureCount(),
		            devices.size(),
		    		slowestDevices);
		    		
		  

		    System.out.println("\n========== FAILED DEVICES ==========");
		    failedDevices.forEach(System.out::println);
		    System.out.println("Total Failed : " + failedDevices.size());
		    System.out.println("====================================");

		    System.out.println("Devices Started  : " + devices.size());
		    System.out.println("Results Recorded : " + MetricsCollector.getResults().size());

		    
		    Assert.assertEquals(
		            failed,
		            0L,
		            "Some devices failed. See FAILED DEVICES list above.");

		} catch (Exception e) {
		    e.printStackTrace();
		}
		
	}
	
	
