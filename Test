	/**
	 * Polls DynamoDB until the device appears, or times out.
	 *
	 * @param deviceId    device to check
	 * @param timeoutSec  max seconds to wait
	 * @param intervalSec seconds between each poll
	 * @return true if device found, false if timed out
	 */
	private boolean waitForDeviceInDB(
	        String deviceId,
	        int timeoutSec,
	        int intervalSec) throws InterruptedException {

	    int elapsed = 0;
	    while (elapsed < timeoutSec) {
	        try {
	            Map<String, String> details =
	                    DynamoDBClientProvider.getDeviceDetails(deviceId);
	            if (details != null && !details.isEmpty()) {
	                return true;
	            }
	        } catch (Exception ignored) {}

	        Thread.sleep(intervalSec * 1000L);
	        elapsed += intervalSec;
	    }
	    return false;
	}

	/**
	 * Polls DynamoDB until lastHeartbeatAt matches sentTime, or times out.
	 *
	 * @param deviceId    device to check
	 * @param sentTime    expected timestamp
	 * @param timeoutSec  max seconds to wait
	 * @param intervalSec seconds between each poll
	 * @return the matched DB timestamp, or the last seen value if timed out
	 */
	private String waitForHeartbeatInDB(
	        String deviceId,
	        String sentTime,
	        int timeoutSec,
	        int intervalSec) throws InterruptedException {

	    int elapsed = 0;
	    String dbTime = null;
	    while (elapsed < timeoutSec) {
	        try {
	            Map<String, String> details =
	                    DynamoDBClientProvider.getDeviceDetails(deviceId);
	            dbTime = details.get("lastHeartbeatAt");
	            if (sentTime.equals(dbTime)) {
	                return dbTime;
	            }
	        } catch (Exception ignored) {}

	        Thread.sleep(intervalSec * 1000L);
	        elapsed += intervalSec;
	    }
	    return dbTime; 
	}
	

	

