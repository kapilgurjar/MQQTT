	                    @Override
	                    public void messageArrived(
	                    String topic,
	                    MqttMessage message) {
	                    long latency =
	                            System.currentTimeMillis()
	                                    - startTime;

	                    System.out.println(
	                            "\nResponse Received");

	                    System.out.println(
	                            "Topic : " + topic);

	                    System.out.println(
	                            "Latency : "
	                                    + latency
