	                    String response =
	                            new String(
	                                    message.getPayload(),
	                                    StandardCharsets.UTF_8);

	                    System.out.println(
	                            "Payload : "
	                                    + response);

	                    try {

	                        ObjectMapper mapper =
	                                new ObjectMapper();

	                        JsonNode root =
	                                mapper.readTree(response);

	                        String correlationToken =
	                                root.path("event")
	                                    .path("header")
	                                    .path("correlationToken")
	                                    .asText();

	                        JsonNode deviceStatus =
	                                root.path("event")
	                                    .path("payload")
	                                    .path("deviceStatuses")
	                                    .get(0);

	                        String responseDeviceId =
	                                deviceStatus.path("deviceId")
	                                            .asText();

	                        boolean success =
	                                deviceStatus.path("success")
	                                            .asBoolean();

	                        String status =
	                                deviceStatus.path("status")
	                                            .asText();

	                        // DeviceId Validation
	                        if (!responseDeviceId.equals(
	                                device.getDeviceId())) {

	                            System.out.println(
	                                    "DeviceId Mismatch");

	                            MetricsCollector2.addResult(
	                                    new ResultInfo(
	                                            device.getDeviceId(),
	                                            latency,
	                                            false));

	                            latch.countDown();
	                            return;
	                        }

	                        // Correlation Token Validation
	                        if (!correlationToken.equals(
	                                device.getDeviceId())) {

	                            System.out.println(
	                                    "Correlation Token Mismatch");

	                            MetricsCollector2.addResult(
	                                    new ResultInfo(
	                                            device.getDeviceId(),
	                                            latency,
	                                            false));

	                            latch.countDown();
	                            return;
	                        }

	                        // Success Validation
	                        if (!success) {

	                            System.out.println(
	                                    "Discovery Success = false");

	                            MetricsCollector2.addResult(
	                                    new ResultInfo(
	                                            device.getDeviceId(),
	                                            latency,
	                                            false));

	                            latch.countDown();
	                            return;
	                        }

	                        // Status Validation
	                        if (!(status.equals("CREATED")
	                                || status.equals("UPDATED"))) {

	                            System.out.println(
	                                    "Invalid Status : "
	                                            + status);

	                            MetricsCollector2.addResult(
	                                    new ResultInfo(
	                                            device.getDeviceId(),
	                                            latency,
	                                            false));

	                            latch.countDown();
	                            return;
	                        }

	                        System.out.println(
	                                "Discovery Validation Passed");

	                        MetricsCollector2.addResult(
	                                new ResultInfo(
	                                        device.getDeviceId(),
	                                        latency,
	                                        true));

	                    } catch (Exception e) {

	                        e.printStackTrace();

	                        MetricsCollector2.addResult(
	                                new ResultInfo(
	                                        device.getDeviceId(),
	                                        latency,
	                                        false));
	                    }

	                    latch.countDown();
	                   

	                    }


