package com.mircom.iot.model;

import java.nio.charset.StandardCharsets;
import java.time.Instant;
import java.time.temporal.ChronoUnit;
import java.util.UUID;

import org.eclipse.paho.client.mqttv3.MqttClient;
import org.eclipse.paho.client.mqttv3.MqttConnectOptions;
import org.eclipse.paho.client.mqttv3.MqttMessage;

import com.mircom.iot.model.AwsIotSslUtil;
import com.mircom.iot.model.DeviceInfo;


	
	public class HeartbeatWorker {

	    private static final String AWS_ENDPOINT =
	            "ssl://auyhz7hlcxtop-ats.iot.us-west-1.amazonaws.com:8883";

	    private final DeviceInfo device;

	    public HeartbeatWorker(DeviceInfo device) {
	        this.device = device;
	    }

	    
	    public String execute() throws Exception {

	        String clientId =
	                "Heartbeat-" + UUID.randomUUID();

	        MqttClient client =
	                new MqttClient(
	                        AWS_ENDPOINT,
	                        clientId);

	        MqttConnectOptions options =
	                new MqttConnectOptions();

	        options.setSocketFactory(
	                AwsIotSslUtil.getSocketFactory(
	                        device.getP12Path(),
	                        device.getPassword()));

	        options.setKeepAliveInterval(60);

	        System.out.println(
	                "\nConnecting Device : "
	                        + device.getDeviceId());

	        client.connect(options);

	        System.out.println(
	                "Connected Successfully");

	        String heartbeatTopic =
	                "t10/"
	                        + device.getDeviceId()
	                        + "/server/telemetry/heartbeat";
	        
	        
	        String timeOfSample =
	                Instant.now()
	                .truncatedTo(ChronoUnit.SECONDS)
	                .toString();

	        String payload =
	                buildHeartbeatPayload(timeOfSample);

//	        String payload =
//	                buildHeartbeatPayload();

	        client.publish(
	                heartbeatTopic,
	                new MqttMessage(
	                        payload.getBytes(
	                                StandardCharsets.UTF_8)));

	        System.out.println(
	                "Heartbeat Sent");

	        System.out.println(
	                "Topic : "
	                        + heartbeatTopic);

	        System.out.println(
	                "Payload : "
	                        + payload);

	        client.disconnect();

	        client.close();

	        System.out.println(
	                "Disconnected Successfully");
	        
	        return timeOfSample;
	    }

	    private String buildHeartbeatPayload(String timeOfSample) {

	        return """
	                {
	                  "event": {
	                    "header": {
	                      "namespace": "Telemetry",
	                      "name": "DeviceHeartbeat",
	                      "messageId": "%s",
	                      "correlationToken": "%s",
	                      "payloadVersion": "3"
	                    },
	                    "payload": {},
	                    "device": {
	                      "deviceId": "%s"
	                    }
	                  },
	                  "context": {
	                    "properties": [
	                      {
	                        "namespace": "KfbAccess.DeviceHealth",
	                        "name": "connectivity",
	                        "value": "OK",
	                        "timeOfSample": "%s",
	                        "uncertaintyInMilliseconds": 0
	                      }
	                    ]
	                  }
	                }
	                """
	                .formatted(
	                        UUID.randomUUID(),
	                        UUID.randomUUID(),
	                        device.getDeviceId(),
//	                        Instant.now()
//	                        .truncatedTo(ChronoUnit.SECONDS)
//	                        .toString());
	                        timeOfSample);
	        
	    }
	}


